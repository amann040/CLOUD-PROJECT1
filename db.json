  "discussions": [
    {
      "id": 1,
      "courseId": 1,
      "userId": 1,
      "title": "Best practices for AWS cost optimization?",
      "content": "I'm looking for tips on how to optimize AWS costs. What are some effective strategies you've used?",
      "createdAt": "2026-04-10",
      "replies": 3
    },
    {
      "id": 2,
      "courseId": 1,
      "userId": 4,
      "title": "EC2 instance types confusion",
      "content": "Can someone explain the difference between t3, m5, and c5 instance types? When should I use each?",
      "createdAt": "2026-04-08",
      "replies": 2
    },
    {
      "id": 3,
      "courseId": 2,
      "userId": 6,
      "title": "Kubernetes vs Docker Swarm",
      "content": "For container orchestration, when would you choose Kubernetes over Docker Swarm?",
      "createdAt": "2026-04-09",
      "replies": 4
    },
    {
      "id": 4,
      "courseId": 3,
      "userId": 8,
      "title": "React hooks vs class components",
      "content": "Should I learn class components or focus only on hooks? What's the industry standard now?",
      "createdAt": "2026-04-11",
      "replies": 1
    },
    {
      "id": 5,
      "courseId": 1,
      "userId": 9,
      "title": "AWS certification path",
      "content": "What's the recommended certification path for someone starting with AWS?",
      "createdAt": "2026-04-12",
      "replies": 0
    }
  ],
  "discussionReplies": [
    {
      "id": 1,
      "discussionId": 1,
      "userId": 4,
      "content": "Use Reserved Instances for predictable workloads and Spot Instances for flexible ones. Also, right-size your instances regularly.",
      "createdAt": "2026-04-10"
    },
    {
      "id": 2,
      "discussionId": 1,
      "userId": 6,
      "content": "Don't forget about storage costs! Use S3 Intelligent Tiering and lifecycle policies.",
      "createdAt": "2026-04-11"
    },
    {
      "id": 3,
      "discussionId": 1,
      "userId": 2,
      "content": "Monitor usage with Cost Explorer and set up billing alerts. Great question!",
      "createdAt": "2026-04-11"
    },
    {
      "id": 4,
      "discussionId": 2,
      "userId": 1,
      "content": "t3 for general purpose/burstable, m5 for memory-intensive apps, c5 for compute-intensive workloads.",
      "createdAt": "2026-04-08"
    },
    {
      "id": 5,
      "discussionId": 2,
      "userId": 6,
      "content": "Also consider r5 for memory-optimized and i3 for storage-optimized workloads.",
      "createdAt": "2026-04-09"
    },
    {
      "id": 6,
      "discussionId": 3,
      "userId": 8,
      "content": "Kubernetes is more feature-rich and better for large-scale deployments. Docker Swarm is simpler for smaller projects.",
      "createdAt": "2026-04-09"
    },
    {
      "id": 7,
      "discussionId": 3,
      "userId": 4,
      "content": "Kubernetes has better community support and more ecosystem tools. But it has a steeper learning curve.",
      "createdAt": "2026-04-10"
    },
    {
      "id": 8,
      "discussionId": 3,
      "userId": 5,
      "content": "For production environments with multiple teams, Kubernetes is definitely the way to go.",
      "createdAt": "2026-04-10"
    },
    {
      "id": 9,
      "discussionId": 3,
      "userId": 6,
      "content": "Docker Swarm is easier to set up and manage for small to medium projects.",
      "createdAt": "2026-04-11"
    },
    {
      "id": 10,
      "discussionId": 4,
      "userId": 6,
      "content": "Focus on hooks! Class components are legacy. React team recommends functional components with hooks.",
      "createdAt": "2026-04-11"
    }
  ],
